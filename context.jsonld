{
  "@context": {
    "@version": 1.1,
    "sc": "https://github.com/Observalytics-SL/aaif/",
    "schema": "https://schema.org/",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "aaif": "https://github.com/Observalytics-SL/aaif/vocab#",

    "sc_standard":       { "@id": "sc:standard",          "@type": "xsd:string" },
    "sc_version":        { "@id": "sc:version",           "@type": "xsd:string" },
    "agent_id":          { "@id": "sc:agentId",           "@type": "@id" },
    "status":            { "@id": "schema:creativeWorkStatus" },
    "tags":              { "@id": "schema:keywords",      "@container": "@list" },

    "agent":             { "@id": "aaif:AgentDefinition" },
    "name":              { "@id": "schema:name" },
    "version":           { "@id": "schema:version" },
    "description":       { "@id": "schema:description" },
    "goal":              { "@id": "aaif:goal" },
    "instructions":      { "@id": "aaif:instructions" },
    "skills":            { "@id": "schema:knowsAbout",    "@container": "@list" },

    "model":             { "@id": "aaif:modelConfig" },
    "provider":          { "@id": "aaif:provider" },
    "provider_id":       { "@id": "aaif:providerId" },
    "base_url":          { "@id": "aaif:baseUrl",        "@type": "@id" },
    "preferred":         { "@id": "aaif:preferredModel" },
    "fallbacks":         { "@id": "aaif:fallbacks",       "@container": "@list" },
    "routing_strategy":  { "@id": "aaif:routingStrategy" },
    "min_context_tokens":{ "@id": "aaif:minContextTokens","@type": "xsd:integer" },
    "temperature":       { "@id": "aaif:temperature",     "@type": "xsd:decimal" },
    "params":            { "@id": "aaif:samplingParams" },
    "response_format":   { "@id": "aaif:responseFormat" },

    "orchestration":        { "@id": "aaif:orchestration" },
    "role":                 { "@id": "aaif:role" },
    "subagents":            { "@id": "aaif:subagents",      "@container": "@list" },
    "handoff":              { "@id": "aaif:handoff",        "@container": "@list" },
    "when":                 { "@id": "aaif:condition" },
    "condition":            { "@id": "aaif:condition" },
    "lang":                 { "@id": "aaif:conditionLang" },
    "expr":                 { "@id": "aaif:conditionExpr" },
    "pipeline":             { "@id": "aaif:pipeline",       "@container": "@list" },
    "parallel_execution":   { "@id": "aaif:parallelExecution", "@type": "xsd:boolean" },
    "max_iterations":       { "@id": "aaif:maxIterations",  "@type": "xsd:integer" },
    "consensus":            { "@id": "aaif:consensus" },

    "context":           { "@id": "aaif:contextItems",    "@container": "@list" },
    "type":              { "@id": "aaif:contextType" },
    "label":             { "@id": "schema:name" },
    "value":             { "@id": "schema:value" },

    "tools":             { "@id": "aaif:tools",           "@container": "@list" },
    "protocol":          { "@id": "aaif:toolProtocol" },
    "parameters_schema": { "@id": "aaif:parametersSchema" },
    "output_schema":     { "@id": "aaif:outputSchema" },
    "endpoint":          { "@id": "schema:url",           "@type": "@id" },
    "auth":              { "@id": "aaif:auth" },
    "cache_ttl_seconds": { "@id": "aaif:cacheTtlSeconds", "@type": "xsd:integer" },
    "timeout_seconds":   { "@id": "aaif:timeoutSeconds",  "@type": "xsd:integer" },
    "rate_limit":        { "@id": "aaif:rateLimit" },

    "memory":            { "@id": "aaif:memory",          "@container": "@list" },
    "scope":             { "@id": "aaif:memoryScope" },
    "key":               { "@id": "schema:name" },
    "content":           { "@id": "schema:text" },
    "backend":           { "@id": "aaif:memoryBackend" },
    "ttl_seconds":       { "@id": "aaif:ttlSeconds",      "@type": "xsd:integer" },
    "embedding_model":   { "@id": "aaif:embeddingModel" },
    "retrieval_strategy":{ "@id": "aaif:retrievalStrategy" },
    "top_k":             { "@id": "aaif:topK",            "@type": "xsd:integer" },

    "constraints":       { "@id": "aaif:constraints",     "@container": "@list" },

    "io":                { "@id": "aaif:ioContract" },
    "input_schema":      { "@id": "aaif:inputSchema" },
    "streaming":         { "@id": "aaif:streaming",       "@type": "xsd:boolean" },
    "format":            { "@id": "aaif:format" },
    "mode":              { "@id": "aaif:executionMode" },

    "events":            { "@id": "aaif:events" },
    "triggers":          { "@id": "aaif:triggers",        "@container": "@list" },
    "on_start":          { "@id": "aaif:onStart" },
    "on_complete":       { "@id": "aaif:onComplete" },
    "on_error":          { "@id": "aaif:onError" },
    "on_tool_call":      { "@id": "aaif:onToolCall" },

    "runtime":           { "@id": "aaif:runtime" },
    "max_retries":       { "@id": "aaif:maxRetries",      "@type": "xsd:integer" },
    "retry_backoff":     { "@id": "aaif:retryBackoff" },
    "concurrency":       { "@id": "aaif:concurrency",     "@type": "xsd:integer" },
    "queue":             { "@id": "aaif:queue" },
    "environment":       { "@id": "aaif:deployEnvironment" },

    "telemetry":              { "@id": "aaif:telemetry" },
    "tracing":                { "@id": "aaif:tracing",          "@type": "xsd:boolean" },
    "log_level":              { "@id": "aaif:logLevel" },
    "metrics":                { "@id": "aaif:metrics",          "@type": "xsd:boolean" },
    "trace_context_header":   { "@id": "aaif:traceContextHeader" },
    "otlp_endpoint":          { "@id": "aaif:otlpEndpoint",     "@type": "@id" },

    "evaluation":        { "@id": "aaif:evaluation" },
    "judge_model":       { "@id": "aaif:judgeModel" },
    "test_cases":        { "@id": "aaif:testCases",       "@container": "@list" },
    "threshold":         { "@id": "aaif:threshold",       "@type": "xsd:decimal" },

    "compliance":           { "@id": "aaif:compliance" },
    "safety_level":         { "@id": "aaif:safetyLevel" },
    "data_residency":       { "@id": "aaif:dataResidency" },
    "pii_handling":         { "@id": "aaif:piiHandling" },
    "audit_log":            { "@id": "aaif:auditLog",     "@type": "xsd:boolean" },
    "human_in_the_loop":    { "@id": "aaif:humanInTheLoop" },

    "vault_ref":          { "@id": "aaif:vaultRef" },
    "vault":              { "@id": "aaif:vaultProvider" },
    "path":               { "@id": "aaif:vaultPath" },
    "version":            { "@id": "aaif:vaultVersion" },
    "extended":           { "@id": "aaif:extendedParams" },
    "required_capabilities": { "@id": "aaif:requiredCapabilities", "@container": "@list" },

    "state_id":           { "@id": "aaif:stateId",           "@type": "@id" },
    "run_id":             { "@id": "aaif:runId",             "@type": "@id" },
    "checkpoint_at":      { "@id": "aaif:checkpointAt",     "@type": "xsd:dateTime" },
    "pipeline_position":  { "@id": "aaif:pipelinePosition" },
    "current_step":       { "@id": "aaif:currentStep" },
    "completed_steps":    { "@id": "aaif:completedSteps",   "@container": "@list" },
    "remaining_steps":    { "@id": "aaif:remainingSteps",   "@container": "@list" },
    "current_subagent":   { "@id": "aaif:currentSubagent" },
    "conversation":       { "@id": "aaif:conversation",     "@container": "@list" },
    "memory_snapshot":    { "@id": "aaif:memorySnapshot",  "@container": "@list" },
    "pending_tool_calls": { "@id": "aaif:pendingToolCalls","@container": "@list" },
    "subagent_states":    { "@id": "aaif:subagentStates",  "@container": "@list" },
    "variables":          { "@id": "aaif:variables" },
    "approval_request":   { "@id": "aaif:approvalRequest" },
    "migration_token":    { "@id": "aaif:migrationToken" },
    "checksum":           { "@id": "aaif:checksum" },
    "token_count":        { "@id": "aaif:tokenCount",       "@type": "xsd:integer" },
    "ttl_remaining_seconds": { "@id": "aaif:ttlRemainingSeconds", "@type": "xsd:integer" },
    "callback_url":       { "@id": "aaif:callbackUrl",      "@type": "@id" },

    "provenance":        { "@id": "prov:Entity" },
    "authored_by":       { "@id": "prov:wasAttributedTo" },
    "source_platform":   { "@id": "dcterms:source" },
    "created_at":        { "@id": "dcterms:created",      "@type": "xsd:dateTime" },
    "updated_at":        { "@id": "dcterms:modified",     "@type": "xsd:dateTime" },
    "license":           { "@id": "dcterms:license",      "@type": "@id" },
    "sc_refs":           { "@id": "dcterms:relation",     "@container": "@list" },
    "signature":         { "@id": "aaif:signature" }
  }
}
