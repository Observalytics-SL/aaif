{
  "x-sc-schema": "agent.schema.json",
  "sc_standard": "SC-006",
  "sc_version": "2.1.0",
  "agent_id": "c3d4e5f6-0003-4000-8000-orchestrat01",
  "status": "active",
  "tags": ["orchestrator", "pipeline", "multi-agent", "business-intelligence"],
  "agent": {
    "name": "Business Intelligence Pipeline",
    "version": "1.0.0",
    "description": "Orchestrator that coordinates three worker agents to produce a weekly business intelligence report: (1) Research Summarizer gathers market news, (2) Invoice Chaser retrieves AR metrics, (3) Report Writer composes the final brief. Results are evaluated by a QA evaluator before delivery.",
    "goal": "Produce a weekly BI report combining market intelligence and accounts-receivable status, validated for accuracy before distribution.",
    "instructions": "You are a BI pipeline coordinator. Run the three workers in sequence: first gather market research, then pull AR metrics, then compose the report. After all workers complete, invoke the QA evaluator. Only deliver the report if QA passes (task_completion ≥ 0.90). If any worker fails, retry once; if it fails again, produce a partial report and flag the missing section.",
    "skills": ["orchestration", "business-intelligence", "pipeline-coordination", "report-generation"],
    "model": {
      "provider": "anthropic",
      "preferred": "claude-opus-4-5",
      "fallbacks": [
        { "provider": "openai", "model": "gpt-4o" },
        { "provider": "google", "model": "gemini-2.5-pro" }
      ],
      "routing_strategy": "quality",
      "min_context_tokens": 128000,
      "temperature": 0.1,
      "response_format": "json"
    },
    "orchestration": {
      "role": "orchestrator",
      "subagents": [
        {
          "ref": "b2c3d4e5-0002-4000-8000-research00001",
          "alias": "researcher",
          "role": "worker",
          "when": { "lang": "always", "nl": "step 1 of pipeline" }
        },
        {
          "ref": "a1b2c3d4-0001-4000-8000-invoice000001",
          "alias": "invoice_chaser",
          "role": "worker",
          "when": { "lang": "always", "nl": "step 2 of pipeline" }
        },
        {
          "ref": "d4e5f6a7-0004-4000-8000-reportwrite1",
          "alias": "report_writer",
          "role": "worker",
          "when": "after researcher and invoice_chaser complete successfully"
        },
        {
          "ref": "e5f6a7b8-0005-4000-8000-qaevaluator1",
          "alias": "qa_evaluator",
          "role": "evaluator",
          "when": "after report_writer completes"
        }
      ],
      "pipeline": ["researcher", "invoice_chaser", "report_writer", "qa_evaluator"],
      "parallel_execution": false,
      "max_iterations": 6,
      "consensus": {
        "strategy": "referee",
        "referee_agent": "qa_evaluator"
      }
    },
    "context": [
      {
        "type": "text",
        "label": "Report structure",
        "value": "Weekly BI Report sections: 1. Market Overview (from researcher), 2. AR Status (from invoice_chaser), 3. Key Risks, 4. Recommended Actions."
      },
      {
        "type": "text",
        "label": "Delivery audience",
        "value": "Executive team — non-technical. Keep language clear. Avoid jargon. Highlight figures prominently."
      }
    ],
    "tools": [
      {
        "name": "invoke_subagent",
        "description": "Invoke a registered subagent by alias and return its output.",
        "protocol": "function",
        "parameters_schema": {
          "type": "object",
          "required": ["alias", "input"],
          "properties": {
            "alias":   { "type": "string" },
            "input":   { "type": "object" },
            "timeout": { "type": "integer" }
          }
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "output":  {},
            "error":   { "type": "string" }
          }
        },
        "timeout_seconds": 180
      },
      {
        "name": "deliver_report",
        "description": "Send the final report to the configured distribution list via email and Slack.",
        "protocol": "function",
        "parameters_schema": {
          "type": "object",
          "required": ["report_markdown"],
          "properties": {
            "report_markdown":   { "type": "string" },
            "subject":           { "type": "string" },
            "distribution_list": { "type": "array", "items": { "type": "string", "format": "email" } }
          }
        },
        "auth": { "type": "bearer", "env_var": "NOTIFICATION_SERVICE_TOKEN" },
        "timeout_seconds": 30
      }
    ],
    "memory": [
      {
        "scope": "long_term",
        "key": "previous_reports",
        "content": "Archive of past weekly BI reports for trend comparison.",
        "backend": "postgres",
        "ttl_seconds": 0
      },
      {
        "scope": "task",
        "key": "pipeline_state",
        "content": "Current pipeline step, intermediate outputs, and error log.",
        "backend": "redis",
        "ttl_seconds": 3600
      }
    ],
    "constraints": [
      "Do not deliver a report that fails QA evaluation (task_completion < 0.90).",
      "Never include raw customer PII in the executive report.",
      "Always include the report generation timestamp and the list of data sources used.",
      "If a worker fails twice, include a clearly marked 'SECTION UNAVAILABLE' placeholder — never fabricate data."
    ],
    "io": {
      "input_schema": {
        "type": "object",
        "properties": {
          "week_ending":         { "type": "string", "format": "date" },
          "research_urls":       { "type": "array", "items": { "type": "string", "format": "uri" } },
          "distribution_list":   { "type": "array", "items": { "type": "string", "format": "email" } },
          "dry_run":             { "type": "boolean", "default": false }
        }
      },
      "output_schema": {
        "type": "object",
        "required": ["report_id", "status"],
        "properties": {
          "report_id":      { "type": "string" },
          "status":         { "type": "string", "enum": ["delivered", "qa_failed", "partial", "error"] },
          "qa_score":       { "type": "number" },
          "sections_ok":    { "type": "array", "items": { "type": "string" } },
          "sections_failed":{ "type": "array", "items": { "type": "string" } },
          "delivered_at":   { "type": "string", "format": "date-time" }
        }
      },
      "streaming": false,
      "format": "json",
      "mode": "async"
    },
    "events": {
      "triggers": [
        {
          "type": "schedule",
          "schedule": "0 7 * * 1",
          "filter": { "lang": "jsonlogic", "expr": { "==": [ { "var": "dry_run" }, false ] }, "nl": "skip dry runs" }
        },
        { "type": "manual" },
        {
          "type": "webhook",
          "webhook_path": "/triggers/bi-pipeline"
        }
      ],
      "on_complete": "log_pipeline_success",
      "on_error":    "alert_ops_and_notify_manager"
    },
    "runtime": {
      "timeout_seconds": 600,
      "max_retries": 1,
      "retry_backoff": "linear",
      "concurrency": 1,
      "async_execution": true,
      "queue": "orchestrator-high",
      "environment": "production"
    },
    "telemetry": {
      "tracing":               true,
      "log_level":             "info",
      "metrics":               true,
      "trace_context_header":  "traceparent",
      "otlp_endpoint":         "http://otel-collector.internal:4317"
    },
    "evaluation": {
      "judge_model": "claude-opus-4-5",
      "metrics": [
        { "name": "task_completion",  "threshold": 0.90 },
        { "name": "faithfulness",     "threshold": 0.88 },
        { "name": "latency_ms",       "threshold": 540000 }
      ]
    },
    "compliance": {
      "safety_level":  "strict",
      "data_residency": "EU",
      "pii_handling":  "anonymize",
      "audit_log":     true,
      "human_in_the_loop": {
        "enabled":          true,
        "trigger":          "before deliver_report tool call",
        "timeout_seconds":  1800
      }
    }
  },
  "provenance": {
    "authored_by":     "platform-team",
    "source_platform": "CrewAI",
    "created_at":      "2026-06-10T08:00:00Z",
    "updated_at":      "2026-06-10T10:00:00Z",
    "license":         "proprietary",
    "sc_refs":         ["SC-005", "SC-007"]
  }
}
