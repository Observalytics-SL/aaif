    { "id": "postgres",  "status": "standard", "since": "2.0.0", "kind": "relational",  "vector": false, "notes": "Good for user/long_term; pgvector adds vector." },
    { "id": "sqlite",    "status": "standard", "since": "2.0.0", "kind": "relational",  "vector": false, "notes": "Single-file local persistence." },
    { "id": "pinecone",  "status": "standard", "since": "2.0.0", "kind": "vector",      "vector": true,  "notes": "Cloud vector search." },
    { "id": "weaviate",  "status": "standard", "since": "2.0.0", "kind": "vector",      "vector": true,  "notes": "Hybrid vector+keyword." },
    { "id": "qdrant",    "status": "standard", "since": "2.0.0", "kind": "vector",      "vector": true,  "notes": "Open-source vector." },
    { "id": "chroma",    "status": "standard", "since": "2.0.0", "kind": "vector",      "vector": true,  "notes": "Embedded vector, zero-infra." },
    { "id": "custom",    "status": "standard", "since": "2.0.0", "kind": "other",       "vector": null,  "notes": "Runtime-defined backend." }
